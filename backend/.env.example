# Security (Generate new random strings for production)
SECRET_KEY=your_globally_unique_secret_key_here
ENCRYPTION_KEY=your_32_byte_url_safe_base64_encoded_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# For local development/demo, SQLite is sufficient
DATABASE_URL="sqlite:///./londoolink.db"
# For production, use PostgreSQL:
# DATABASE_URL="postgresql+psycopg2://user:password@host:port/dbname"

# AI Providers
GROQ_API_KEY=gsk_your_groq_api_key_here
# Optional: if you use these provider fallbacks
OPENAI_API_KEY=sk-your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
CLAUDE_API_KEY=your_claude_key_here

# Web Crawling (Firecrawl - https://firecrawl.dev)
FIRECRAWL_API_KEY=fc-your_firecrawl_api_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=https://www.londoolink.tech/login

# WhatsApp
WHATSAPP_APP_ACCESS_TOKEN=your_access_token

# Vector DB
# For Render, you typically use a persistent disk or a cloud hosted vector DB
CHROMA_DB_PATH=./chroma_db

# External Services
OLLAMA_BASE_URL=http://your-ollama-instance-url:11434

# System Config
ENVIRONMENT=production
# Update this to your real Vercel frontend URL
ALLOWED_ORIGINS=https://londoolink-ai.vercel.app
# Critical for faster Render deploys
PORT=8000

# Auth0 Token Vault (required in non-development environments)
AUTH0_DOMAIN=your-tenant.auth0.com                          # Auth0 tenant domain
AUTH0_CLIENT_ID=your_auth0_application_client_id            # Auth0 application client ID
AUTH0_CLIENT_SECRET=your_auth0_application_client_secret    # Auth0 application client secret
AUTH0_AUDIENCE=https://your-tenant.auth0.com/api/v2/        # Auth0 API audience identifier
AUTH0_TOKEN_VAULT_BASE_URL=https://your-tenant.auth0.com/api/v2/token-vault  # Token Vault base URL
AUTH0_M2M_CLIENT_ID=your_m2m_client_id                      # M2M application client ID for vault access
AUTH0_M2M_CLIENT_SECRET=your_m2m_client_secret              # M2M application client secret

# OAuth redirect base
FRONTEND_URL=https://londoolink-ai.vercel.app               # Frontend base URL for OAuth redirects

# Notion OAuth (optional — only required when Notion integration is enabled)
NOTION_CLIENT_ID=your_notion_integration_client_id          # Notion integration client ID
NOTION_CLIENT_SECRET=your_notion_integration_client_secret  # Notion integration client secret
NOTION_REDIRECT_URI=https://your-backend-url/api/v1/integrations/notion/callback  # Notion OAuth redirect URI